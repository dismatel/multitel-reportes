# ============================================================
# Multitel Reportes — Environment Variables Template
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el .env con valores reales
# ============================================================

# ──────────────────────────────────────────
# Azure Active Directory (App Registration)
# ──────────────────────────────────────────
# Nombre del App Registration: Multitel Reportes
# Tipo de cuenta: solo este directorio organizativo (single tenant)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# Permisos Graph API requeridos (delegados):
# User.Read, Sites.ReadWrite.All, Files.ReadWrite.All,
# Sites.Manage.All, offline_access, openid, profile

# ──────────────────────────────────────────
# Azure Functions
# ──────────────────────────────────────────
FUNCTIONS_APP_NAME=multitel-reportes-fn
AZURE_RESOURCE_GROUP=rg-multitel-reportes
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_FUNCTIONS_MASTER_KEY=your-functions-master-key

# ──────────────────────────────────────────
# Microsoft Dataverse
# ──────────────────────────────────────────
DATAVERSE_URL=https://orgXXXXXXXX.crm.dynamics.com
DATAVERSE_ENTITY_REPORTES=multitel_reportes
DATAVERSE_ENTITY_TECNICOS=multitel_tecnicos

# ──────────────────────────────────────────
# Microsoft Graph API / OneDrive
# ──────────────────────────────────────────
GRAPH_API_BASE=https://graph.microsoft.com/v1.0
ONEDRIVE_ROOT_PATH=/Multitel/Reportes
SHAREPOINT_SITE_ID=your-sharepoint-site-id

# ──────────────────────────────────────────
# Azure API Management
# ──────────────────────────────────────────
APIM_BASE_URL=https://multitel-apim.azure-api.net
APIM_SUBSCRIPTION_KEY=your-apim-subscription-key
RATE_LIMIT_PER_MINUTE=60

# ──────────────────────────────────────────
# Play Integrity API
# ──────────────────────────────────────────
PLAY_INTEGRITY_DECRYPTION_KEY=your-play-integrity-decryption-key
PLAY_INTEGRITY_VERIFICATION_KEY=your-play-integrity-verification-key
PLAY_PACKAGE_NAME=com.multitel.reportes

# ──────────────────────────────────────────
# Expo / EAS Build
# ──────────────────────────────────────────
EXPO_TOKEN=your-expo-token
EAS_PROJECT_ID=your-eas-project-id
ANDROID_KEYSTORE_PASSWORD=your-keystore-password
ANDROID_KEY_ALIAS=multitel-reportes
ANDROID_KEY_PASSWORD=your-key-password

# ──────────────────────────────────────────
# Microsoft Teams (Notificaciones)
# ──────────────────────────────────────────
TEAMS_WEBHOOK_SUPERVISORES=https://outlook.office.com/webhook/...
TEAMS_CHANNEL_ID=your-teams-channel-id
TEAMS_TEAM_ID=your-teams-team-id

# ──────────────────────────────────────────
# Power Automate
# ──────────────────────────────────────────
POWER_AUTOMATE_FLOW_URL=https://prod-XX.westus.logic.azure.com/workflows/...

# ──────────────────────────────────────────
# LibreOffice (headless PDF conversion)
# ──────────────────────────────────────────
LIBREOFFICE_PATH=/usr/bin/libreoffice

# ──────────────────────────────────────────
# Seguridad
# ──────────────────────────────────────────
JWT_AUDIENCE=api://multitel-reportes
JWT_ISSUER=https://login.microsoftonline.com/${AZURE_TENANT_ID}/v2.0
PPTX_TEMPLATE_PATH=/templates/plantilla_multitel.pptx
